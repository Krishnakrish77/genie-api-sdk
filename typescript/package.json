{
  "name": "genie-api-sdk",
  "version": "0.1.0-beta.1",
  "description": "Unofficial TypeScript SDK for the Genie Headless API",
  "license": "MIT",
  "homepage": "https://github.com/Krishnakrish77/genie-api-sdk#readme",
  "repository": { "type": "git", "url": "git+https://github.com/Krishnakrish77/genie-api-sdk.git", "directory": "typescript" },
  "bugs": { "url": "https://github.com/Krishnakrish77/genie-api-sdk/issues" },
  "keywords": ["agentic", "genie", "headless-api", "sdk"],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run check && npm test"
  },
  "engines": { "node": ">=18" },
  "packageManager": "npm@10.9.2",
  "publishConfig": { "access": "public", "provenance": true },
  "devDependencies": { "typescript": "^7.0.2" }
}
